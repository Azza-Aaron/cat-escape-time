{
  "name": "cat-escape-time",
  "private": true,
  "scripts": {
    "dev": "npm-run-all -s docker:up wait:api client:dev",
    "run-dev": "npm run dev",
    "docker:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build db api",
    "wait:api": "wait-on http://127.0.0.1:3001/health",
    "client:dev": "npm run dev --prefix client",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "wait-on": "^8.0.1"
  }
}
